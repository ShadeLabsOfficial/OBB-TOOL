#!/data/user/0/com.termux/files/usr/bin/bash

# Warna
NC='\033[0m'
LGREEN='\033[1;32m'
LRED='\033[1;31m'
YELLOW='\033[1;33m'
LBLUE='\033[1;36m'
PURPLE='\033[1;35m'

clear
# Banner Utama bergaya kotak seperti screenshot kamu
echo -e "${LBLUE}в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ${NC}"
echo -e "${LBLUE}в”Ӯ${NC}  рҹ”Ҙ  ${YELLOW}GINOGA PREMIUM VVIP TOOL${NC}   рҹ”Ҙ   ${LBLUE}в”Ӯ${NC}"
echo -e "${LBLUE}в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө${NC}"
echo -e "${LBLUE}в”Ӯ${NC}   рҹӣ пёҸ   ${LGREEN}OBB UNPACK & REPACK TOOL${NC}   рҹӣ пёҸ   ${LBLUE}в”Ӯ${NC}"
echo -e "${LBLUE}в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө${NC}"
echo -e "${LBLUE}в”Ӯ${NC}   рҹҢҗ   ${PURPLE}POWERED BY @SHADELABS${NC}         ${LBLUE}в”Ӯ${NC}"
echo -e "${LBLUE}в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ${NC}"

echo -e "${LBLUE}рҹ”Қ CHECKING USER...${NC}"
sleep 0.5
echo -e "${LGREEN}вң“ Access granted!${NC}"
echo ""

# Fungsi Menu Utama
function main_menu {
    echo -e "${LBLUE}в”Ңв”Җв”Җв”Җ${NC} ${YELLOW}TOOL UNPACK & REPACK${NC} ${LBLUE}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ${NC}"
    echo -e " ${LBLUE}[1]${NC} ${LGREEN}BGMI TOOL${NC}"
    echo -e " ${LBLUE}[2]${NC} ${LGREEN}PUBG GLOBAL TOOL${NC}"
    echo -e " ${LBLUE}[3]${NC} ${LGREEN}PUBG LITE TOOL${NC}"
    echo -e " ${LBLUE}[4]${NC} ${LGREEN}PUBG KR/TW/VN TOOL${NC}"
    echo -e " ${LBLUE}[5]${NC} ${LRED}EXIT${NC}"
    echo -e "${LBLUE}в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ${NC}"
    echo -ne "${YELLOW}в—Ҷ SELECT OPTION: ${NC}"
    read opt

    case $opt in
        1)
            echo -e "\n${LGREEN}Membuka BGMI Tool...${NC}"
            sleep 0.5
            ./unpackobb
            ;;
        2)
            echo -e "\n${LGREEN}Membuka PUBG Global Tool...${NC}"
            sleep 0.5
            # Memanggil file mesin kedua jika ada
            if [ -f "./unpackobb1" ]; then
                ./unpackobb1
            else
                ./unpackobb
            fi
            ;;
        3)
            echo -e "\n${LGREEN}Membuka PUBG Lite Tool...${NC}"
            sleep 0.5
            if [ -f "./unpackobb2" ]; then
                ./unpackobb2
            else
                ./unpackobb
            fi
            ;;
        4)
            echo -e "\n${LGREEN}Membuka PUBG KR/TW/VN Tool...${NC}"
            sleep 0.5
            if [ -f "./CHEN" ]; then
                ./CHEN
            else
                ./unpackobb
            fi
            ;;
        5)
            echo -e "\n${LRED}Keluar dari Tool. Sampai jumpa!${NC}"
            exit 0
            ;;
        *)
            echo -e "\n${LRED}Pilihan salah! Silakan coba lagi.${NC}"
            sleep 1
            clear
            main_menu
            ;;
    esac
}

# Jalankan Menu
main_menu

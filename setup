#!/data/user/0/com.termux/files/usr/bin/bash
function Coloring {
NC='\033[0m'
LRED='\033[1;31m'
LGREEN='\033[1;32m'
YELLOW='\033[1;33m'
PURPLE='\033[1;35m'
LBLUE='\033[1;36m'
}
colors=("\033[31m" "\033[33m" "\033[32m" "\033[36m" "\033[34m" "\033[35m")
reset="\033[0m"

rainbow() {
    local text="$1"
    local i
    local text_length=${#text}
    for ((i=0; i<text_length; i++)); do
        color_index=$((i % ${#colors[@]}))
        printf "${colors[$color_index]}${text:$i:1}"
    done
    printf "$reset\n"
}

banner() {
rainbow "=========================================================="
toilet "$(figlet "GINOGA TOOL")" -f term --gay  | pv -qL 3000
rainbow "=========================================================="
toilet "  𝗧𝗘𝗟𝗘𝗚𝗥𝗔𝗠 𝗖𝗛𝗔𝗡𝗡𝗘𝗟 𝗦𝗛𝗔𝗗𝗘𝗟𝗔𝗕𝗦  " -f term -F border --gay  | pv -qL 3000
toilet -f term -F gay "   𝗢𝗕𝗕 𝗧𝗢𝗢𝗟 𝗣𝗥𝗘𝗠𝗜𝗨𝗠 " | pv -qL 2999
toilet "  𝗣𝗨𝗕𝗚 𝗕𝗚𝗠𝗜 𝗣𝗨𝗕𝗚 𝗟𝗜𝗧𝗘 𝗞𝗥 𝗧𝗪 𝗩𝗡𝗚 " -f term -F border --gay  | pv -qL 3000
toilet -f term -F gay "   𝗖𝗢𝗣𝗬𝗥𝗜𝗚𝗛𝗧 @𝗦𝗛𝗔𝗗𝗘𝗟𝗔𝗕𝗦𝗢𝗙𝗙𝗜𝗖𝗜𝗔𝗟 " | pv -qL 2999
}

clear
Coloring
banner
sleep 0.2

quickbms_dir=$PREFIX/share/quickbms
if [ -f $HOME/OBB-TOOL ]; then
chmod +x $HOME/OBB-TOOL
mv $HOME/OBB-TOOL $PREFIX/bin
fi

function redirect {
toilet "   TOOL INSTALL DONE   " -f term -F border --gay  | pv -qL 3000
  count=0
  total=3
  start=`date +%s`
  while [ $count -lt $total ]
  do
    sleep 1
    cur=`date +%s`
    count=$(( $count + 1 ))
    pd=$(( $count * 73 / $total ))
    runtime=$(( $cur-$start ))
    estremain=$(( ($runtime * $total / $count)-$runtime ))
    printf "\r%d.%d%% complete - est %d:%0.2d remaining\e[K" $(( $count*100/$total )) $(( ($count*1000/$total)%10)) $(( $estremain/60 )) $(( $estremain%60 ))
  done
  printf "\n"

if [ -f $HOME/OBB-TOOL/setup ]; then
chmod +x unpackobb repack.bms unpack.bms
chmod +x unpackobb1 repack1.bms unpack1.bms
chmod +x unpackobb2 repack2.bms unpack2.bms
chmod +x zipOBB setup CHEN CHEN1 CHEN2 rani
fi

clear
# MASUK KE MENU KUSTOM GINOGA VVIP MULTI-GAME
main_menu
}

function main_menu {
    echo -e "${LBLUE}┌────────────────────────────────────────┐${NC}"
    echo -e "${LBLUE}│${NC}  🔥  ${YELLOW}GINOGA PREMIUM VVIP TOOL${NC}   🔥   ${LBLUE}│${NC}"
    echo -e "${LBLUE}├────────────────────────────────────────┤${NC}"
    echo -e "${LBLUE}│${NC}   🛠️   ${LGREEN}OBB UNPACK & REPACK TOOL${NC}   🛠️   ${LBLUE}│${NC}"
    echo -e "${LBLUE}├────────────────────────────────────────┤${NC}"
    echo -e "${LBLUE}│${NC}   🌐   ${PURPLE}POWERED BY @SHADELABS${NC}         ${LBLUE}│${NC}"
    echo -e "${LBLUE}└────────────────────────────────────────┘${NC}"
    echo ""
    echo -e "${LBLUE}┌───${NC} ${YELLOW}TOOL UNPACK & REPACK${NC} ${LBLUE}─────────────────┐${NC}"
    echo -e " ${LBLUE}[1]${NC} ${LGREEN}BGMI TOOL${NC}"
    echo -e " ${LBLUE}[2]${NC} ${LGREEN}PUBG GLOBAL TOOL${NC}"
    echo -e " ${LBLUE}[3]${NC} ${LGREEN}PUBG LITE TOOL${NC}"
    echo -e " ${LBLUE}[4]${NC} ${LGREEN}PUBG KR/TW/VN TOOL${NC}"
    echo -e " ${LBLUE}[5]${NC} ${LRED}EXIT${NC}"
    echo -e "${LBLUE}└────────────────────────────────────────┘${NC}"
    echo -ne "${YELLOW}◆ SELECT OPTION: ${NC}"
    read opt

    case $opt in
        1)
            echo -e "\n${LGREEN}Membuka BGMI Tool...${NC}"
            sleep 0.5
            ./unpackobb
            ;;
        2)
            echo -e "\n${LGREEN}Membuka PUBG Global Tool...${NC}"
            sleep 0.5
            if [ -f "./unpackobb1" ]; then ./unpackobb1; else ./unpackobb; fi
            ;;
        3)
            echo -e "\n${LGREEN}Membuka PUBG Lite Tool...${NC}"
            sleep 0.5
            if [ -f "./unpackobb2" ]; then ./unpackobb2; else ./unpackobb; fi
            ;;
        4)
            echo -e "\n${LGREEN}Membuka PUBG KR/TW/VN Tool...${NC}"
            sleep 0.5
            if [ -f "./CHEN" ]; then ./CHEN; else ./unpackobb; fi
            ;;
        5)
            echo -e "\n${LRED}Keluar dari Tool. Sampai jumpa!${NC}"
            exit 0
            ;;
        *)
            echo -e "\n${LRED}Pilihan salah!${NC}"
            sleep 1
            clear
            main_menu
            ;;
    esac
}

function quickbms_check {
echo -e "${LGREEN}Checking required program..${NC}"
FILE=$quickbms_dir/quickbms_4gb_files
if [ -f "$FILE" ]; then
echo -e "${LGREEN}Program has been installed.${NC}"
redirect
else
echo -e "${LRED}PROGRAM NOT FOUND.${NC}"
quickbms_install
redirect
fi
}

function quickbms_install {
echo -e "${LGREEN}Installing required program..${NC}"
sleep 1
wget http://aluigi.altervista.org/papers/quickbms_linux.zip
sleep 1
unzip quickbms_linux.zip
sleep 1
mkdir $quickbms_dir
sleep 1
chmod +x quickbms_4gb_files quickbms
sleep 1
cp quickbms_4gb_files quickbms  $quickbms_dir
sleep 1
rm -rf quickbms*
sleep 1
chmod +x script/*.bms
}

toilet " CHECKING INSTALL TOOL " -f term -F border --gay  | pv -qL 3000
echo -e "${LGREEN}Checking Required packages${NC}"
packages=("wget" "unzip" "zip" "pv" "figlet" "toilet" "curl" "rsync" "x11-repo" "qemu-system-i386" "qemu-user-i386")
for pkg in ${packages[@]}; do
is_pkg_installed=$(dpkg-query -W --showformat='${Status}\n' ${pkg} | grep "install ok installed")
if [ "${is_pkg_installed}" == "install ok installed" ]; then
echo -e ${LGREEN}${pkg}${NC} is installed.
else [ "" = "${is_pkg_installed}" ];
echo -e "${LRED}No ${pkg}. Setting up ${pkg}.${NC}"
pkg install ${pkg} -y
fi
done
quickbms_check
